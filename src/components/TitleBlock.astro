---
const {
  mainText = "Club Doméstico",
  subText = "Electro y afecto en formato DIY",
  emoji= "👽",
} = Astro.props;
---

<div class="flex flex-col gap-1 items-center text-white">
  <h1
    class="glitch heading font-[800] uppercase text-[2.25rem] sm:text-[2.5rem] xl:text-[2.75rem] 2xl:text-5xl italic tracking-tighter relative text-shadow-black text-shadow-md/30"
    data-text={mainText}
  >
    {mainText}
  </h1>
  {
    subText && (
      <h2 class="text-xl sm:text-[1.400rem] 2xl:text-2xl text-shadow-lg/30 font-medium">
        {subText}
        {emoji}
      </h2>
    )
  }
</div>
