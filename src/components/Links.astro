---
const links = [
  // {
  //   text: "AFTER HOURS / 13 MAR",
  //   url: "https://www.instagram.com/p/DVKG0fNgYbI/",
  //   type: "image",
  //   color: "primary",
  //   image: "/img/after-hours-001.jpg",
  // },
  {
    text: "Próximos Eventos",
    url: "/calendar",
    type: "button",
    color: "primary",
    image: null,
  },
  {
    text: "Merch",
    url: "/merch",
    type: "button",
    color: "secondary",
    image: null,
  },
  {
    text: "Contáctanos",
    url: "mailto:clubdomestico@gmail.com",
    type: "button",
    color: "secondary",
    image: null,
  },
];
---

<div class="flex flex-col gap-4 w-full mx-auto">
  {
    links.map((link) => (
      <a
        href={link.url}
        class={`group relative flex items-center justify-center w-full px-6 py-4
          rounded-full border-3 font-bold text-lg uppercase text-white text-center
          backdrop-blur-sm shadow-2xl/20
          transition-all duration-300 hover:scale-105
          ${
            link.color === "primary"
              ? "border-emerald-300 bg-emerald-500/25 hover:bg-emerald-500/50 hover:shadow-emerald-400/20 hover:shadow-lg"
              : "border-pink-300 bg-pink-400/25 hover:bg-pink-400/50 hover:shadow-pink-400/20 hover:shadow-lg"
          }
        `}
        style={
          link.type === "image"
            ? `background-image: url('${link.image}'); background-size: cover; background-position: center;`
            : ""
        }
      >
        {link.type === "image" && (
          <div class="absolute inset-0 rounded-full bg-black/50 pointer-events-none" />
        )}
        <span class="relative z-10">{link.text}</span>
      </a>
    ))
  }
</div>
