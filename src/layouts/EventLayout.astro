---
import Head from '../components/Head.astro';
import GrainOverlay from '../components/GrainOverlay.astro';
import HeaderEvent from '../components/HeaderEvent.astro';
import ButtonHome from '../components/ButtonHome.astro';

interface Props {
mainText?: string;
subText?: string;
showButtonHome?: boolean; // New optional boolean prop
size?: 'block' | 'full-width'; // New optional prop for layout size
}

const { mainText = "Club Doméstico", subText = "Electro y afecto en formato DIY 👽", showButtonHome = true, size = 'block' } = Astro.props;
const mainClasses = size === 'full-width' ? 'flex flex-col w-full gap-4 relative z-10 py-6' : 'flex flex-col w-full gap-4 relative z-10 px-4 py-6';
---
<html lang="en">
<Head />
<body
class="flex flex-col items-center md:justify-center min-h-dvh w-full"
>
<GrainOverlay />

<main class={mainClasses}>
  <HeaderEvent mainText={mainText} subText={subText} />

  <slot />

  {showButtonHome && <ButtonHome />}
</main>

</body>
</html>