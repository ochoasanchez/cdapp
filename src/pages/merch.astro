---
import { Image } from "astro:assets";
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import merchImage from "../../public/img/merch.jpg";
import ImageCarousel from "../components/ImageCarousel.astro";
import ButtonHome from "../components/ButtonHome.astro";
---

<BaseLayout mainText="Merch" subText="" showButtonHome={false}>
  <div id="img-container" class="w-full overflow-hidden">
    <ImageCarousel
      src={merchImage}
      alt="A collage of various merchandise items"
    />
  </div>
  <div
    id="buttons"
    class="flex flex-col md:flex-row gap-6 w-full md:w-10/12 lg:w-8/12 xl:w-6/12 mx-auto justify-center"
  >
    <ButtonHome />
    <a
      id="card-button"
      href="https://api.whatsapp.com/send?phone=584145805584&text=Hola%2C%20quisiera%20m%C3%A1s%20info%20sobre%20la%20merch%20de%20Club%C2%A0Dom%C3%A9stico"
      class="flex items-center justify-center w-full px-6 py-4 rounded-full border-3 border-emerald-300 bg-emerald-400/25 backdrop-blur-sm font-bold text-lg uppercase text-white text-center shadow-2xl/20 transition-all duration-300 hover:scale-105 hover:bg-emerald-300/50 hover:shadow-emerald-400/20 hover:shadow-lg"
    >
      Comprar por WhatsApp
    </a>
  </div>
</BaseLayout>

<style is:global>
  html,
  body {
    overflow-y: auto !important;
  }
</style>
<style>
  #img-container {
    width: 100vw;
    margin-left: calc(50% - 50vw);
  }
</style>
